      </div>

      <!-- Card 2 clone: Communication -->
      <div style="background:linear-gradient(160deg,#0d2c24,#163d30,#0d2c24);border-radius:20px;overflow:hidden;display:flex;flex-direction:column;position:relative;min-height:320px;min-width:calc(85vw - 1rem);max-width:320px;flex-shrink:0;scroll-snap-align:start;">
        <div style="height:3px;background:linear-gradient(90deg,#34d399,rgba(52,211,153,.3));flex-shrink:0;"></div>
        <div style="padding:1.75rem 1.5rem 1.5rem;flex:1;display:flex;flex-direction:column;justify-content:space-between;">
          <div>
            <div style="font-size:.5rem;letter-spacing:.22em;text-transform:uppercase;color:rgba(232,103,58,1);font-weight:700;margin-bottom:1rem;font-family:'DM Sans',sans-serif;">Communication</div>
            <div style="font-family:'Playfair Display',Georgia,serif;font-size:1.6rem;font-weight:700;color:white;line-height:1.05;margin-bottom:.65rem;">How you each actually show up.</div>
            <div style="display:flex;flex-direction:column;gap:.45rem;">
              <div style="display:flex;align-items:center;gap:.5rem;">
                <span style="font-size:.62rem;color:#E8673A;font-weight:700;width:38px;flex-shrink:0;font-family:'DM Sans',sans-serif;">Sarah</span>
                <div style="flex:1;background:rgba(255,255,255,.08);border-radius:3px;height:4px;overflow:hidden;"><div style="background:#E8673A;height:4px;width:15%;border-radius:3px;"></div></div>
                <span style="font-size:.58rem;color:rgba(255,255,255,.55);font-family:'DM Sans',sans-serif;white-space:nowrap;">Engage fast</span>
              </div>
              <div style="display:flex;align-items:center;gap:.5rem;">
                <span style="font-size:.62rem;color:#7B9FFF;font-weight:700;width:38px;flex-shrink:0;font-family:'DM Sans',sans-serif;">James</span>
                <div style="flex:1;background:rgba(255,255,255,.08);border-radius:3px;height:4px;overflow:hidden;"><div style="background:#5B7FE8;height:4px;width:80%;border-radius:3px;"></div></div>
                <span style="font-size:.58rem;color:rgba(255,255,255,.55);font-family:'DM Sans',sans-serif;white-space:nowrap;">Withdraw first</span>
              </div>
            </div>
