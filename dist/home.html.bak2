              <line x1="1" y1="55" x2="198" y2="55" stroke="rgba(255,255,255,.6)" stroke-width="2"/>
              <!-- Dashed connector: Sarah W(top-left) to James Y(bottom-left) -->
              <line x1="50" y1="27" x2="52" y2="80" stroke="rgba(255,255,255,.5)" stroke-width="1.5" stroke-dasharray="4,3"/>
              <!-- Sarah dot W - top-left -->
              <circle cx="50" cy="27" r="16" fill="url(#mga)"/>
              <circle cx="50" cy="27" r="10" fill="#E8673A"/>
              <circle cx="50" cy="27" r="10" fill="none" stroke="white" stroke-width="2"/>
