<!-- HERO -->
<div class="hero">

  <!-- Gradient blobs — desktop: top-right purple + lower-right orange + left indigo -->
  <div class="hero-blobs" aria-hidden="true">
    <div class="hero-blob" style="top:-180px;right:-160px;width:820px;height:820px;background:radial-gradient(ellipse at 55% 42%, rgba(155,93,229,0.28) 0%, rgba(155,93,229,0.12) 35%, rgba(155,93,229,0.04) 58%, transparent 72%);"></div>
    <div class="hero-blob" style="bottom:-100px;right:-60px;width:560px;height:560px;background:radial-gradient(ellipse at 50% 55%, rgba(232,103,58,0.18) 0%, rgba(232,103,58,0.06) 50%, transparent 68%);"></div>
    <!-- Third desktop blob: indigo left edge for depth -->
    <div class="hero-blob" style="top:60px;left:-120px;width:420px;height:420px;background:radial-gradient(ellipse at 30% 50%, rgba(27,95,232,0.10) 0%, transparent 60%);"></div>
    <!-- Mobile-only: centred bloom behind headline -->
    <div class="hero-blob" style="top:-60px;left:50%;transform:translateX(-50%);width:560px;height:500px;background:radial-gradient(ellipse at 50% 36%, rgba(155,93,229,0.30) 0%, rgba(155,93,229,0.12) 38%, rgba(232,103,58,0.12) 55%, transparent 70%);display:none" id="hero-blob-mobile"></div>
  </div>
  <style>
    @media(max-width:900px){#hero-blob-mobile{display:block !important}}
    @media(max-width:900px){.hero-blobs .hero-blob:not(#hero-blob-mobile){display:none}}
  </style>

  <div class="hero-left">
    <p class="eyebrow fu1" style="font-size:.6rem;"><span class="eyebrow-dot"></span>A new kind of relationship tool</p>
    <h1 class="fu2">Understand each other deeply.<br><em>And how to grow together.</em></h1>
    <p class="hero-love fu3" style="font-size:.95rem;color:var(--ink);font-weight:500;line-height:1.6;margin-bottom:.75rem;max-width:420px;font-family:'DM Sans',sans-serif;">You love each other. Attune uncovers how you are actually wired to help you learn how to grow together.</p>
    <p class="hero-sub fu3">Complete a series of independent exercises to build a precise picture of your relationship and growth opportunities.</p>
    

    <!-- FOR YOU / GIVE AS GIFT — stacked, narrow -->
    <div class="hero-ctas fu3" style="display:flex;flex-direction:column;align-items:flex-start;gap:.65rem;">
      <a href="/offerings" class="btn-primary" style="width:auto;padding:.9rem 2.4rem;">Get started →</a>
      <a href="/offerings#gift" class="btn-ghost" style="font-size:.78rem;padding-left:.5rem;">Give it as a gift →</a>
    </div>

    <!-- Mobile-only: mini gap preview strip (desktop has animated card on the right) -->
    <div id="hero-gap-strip" style="display:none;margin-top:1.5rem;">
      <div style="font-size:.55rem;letter-spacing:.2em;text-transform:uppercase;color:var(--muted);font-family:'DM Sans',sans-serif;font-weight:700;margin-bottom:.65rem;">A glimpse at your results</div>
      <div style="background:linear-gradient(150deg,#1e1a42,#2c2860);border-radius:12px;overflow:hidden;">
        <div id="hgs-bar" style="height:2px;background:linear-gradient(90deg,#1B5FE8,#1B5FE844);transition:background 0.5s;"></div>
        <div style="padding:.9rem 1rem;display:grid;grid-template-columns:1fr auto 1fr;align-items:start;gap:.5rem;">
          <div>
            <div style="font-size:.46rem;letter-spacing:.16em;text-transform:uppercase;color:rgba(232,103,58,.6);font-family:'DM Sans',sans-serif;font-weight:700;margin-bottom:.3rem;">Sarah</div>
            <div id="hgs-her" style="font-family:'Playfair Display',Georgia,serif;font-size:.88rem;font-weight:700;color:white;line-height:1.25;">Address it now.</div>
          </div>
          <div style="display:flex;align-items:center;padding-top:.9rem;">
            <div id="hgs-pill" style="width:18px;height:18px;border-radius:50%;background:rgba(27,95,232,.25);border:1px solid rgba(27,95,232,.45);display:flex;align-items:center;justify-content:center;transition:background .5s,border-color .5s;">
              <span style="font-size:.42rem;color:rgba(255,255,255,.45);font-weight:700;font-family:'DM Sans',sans-serif;">vs</span>
            </div>
          </div>
          <div>
            <div style="font-size:.46rem;letter-spacing:.16em;text-transform:uppercase;color:rgba(27,95,232,.7);font-family:'DM Sans',sans-serif;font-weight:700;margin-bottom:.3rem;">James</div>
            <div id="hgs-his" style="font-family:'Playfair Display',Georgia,serif;font-size:.88rem;font-weight:700;color:white;line-height:1.25;">Needs space first.</div>
          </div>
        </div>
        <div style="padding:.45rem 1rem .6rem;display:flex;align-items:center;justify-content:space-between;">
          <div id="hgs-dim" style="font-size:.44rem;letter-spacing:.16em;text-transform:uppercase;color:rgba(255,255,255,.2);font-family:'DM Sans',sans-serif;">Conflict style</div>
          <div style="display:flex;gap:3px;" id="hgs-dots">
            <div style="width:12px;height:2px;border-radius:2px;background:rgba(255,255,255,.4);transition:all .4s;"></div>
            <div style="width:4px;height:2px;border-radius:2px;background:rgba(255,255,255,.15);transition:all .4s;"></div>
            <div style="width:4px;height:2px;border-radius:2px;background:rgba(255,255,255,.15);transition:all .4s;"></div>
          </div>
        </div>
      </div>
    </div>
    <style>@media(max-width:900px){#hero-gap-strip{display:block!important}}</style>
  </div>

  <div class="hero-right fu3">
    <div style="display:flex;flex-direction:column;height:100%;justify-content:center;gap:1rem;">

      <!-- ── COUPLE MAP HERO VISUAL ── -->
      <div style="background:white;border-radius:20px;padding:1.25rem 1.25rem 1rem;box-shadow:0 6px 32px rgba(14,11,7,.10),0 1px 8px rgba(14,11,7,.06);border:1.5px solid #EDE8E2;">
        <div style="font-size:.5rem;letter-spacing:.22em;text-transform:uppercase;color:#E8673A;font-weight:700;margin-bottom:.6rem;font-family:'DM Sans',sans-serif;">Your Couple Map · Sarah &amp; James</div>
        <!-- Mini 2x2 map SVG -->
        <div style="position:relative;width:100%;aspect-ratio:1.2;max-height:200px;overflow:visible;">
          <svg viewBox="0 0 400 340" style="width:100%;height:100%;" xmlns="http://www.w3.org/2000/svg">
            <defs>
              <linearGradient id="hgW" x1="0%" y1="0%" x2="100%" y2="100%"><stop offset="0%" stop-color="#FFE4D6"/><stop offset="100%" stop-color="#FFCDB3"/></linearGradient>
              <linearGradient id="hgX" x1="0%" y1="0%" x2="100%" y2="100%"><stop offset="0%" stop-color="#DAE4FF"/><stop offset="100%" stop-color="#C5D3FF"/></linearGradient>
              <linearGradient id="hgY" x1="0%" y1="0%" x2="100%" y2="100%"><stop offset="0%" stop-color="#EAE0FF"/><stop offset="100%" stop-color="#DDD0FF"/></linearGradient>
              <linearGradient id="hgZ" x1="0%" y1="0%" x2="100%" y2="100%"><stop offset="0%" stop-color="#EBEBEB"/><stop offset="100%" stop-color="#DEDEDE"/></linearGradient>
              <radialGradient id="hga"><stop offset="0%" stop-color="#E8673A" stop-opacity=".4"/><stop offset="100%" stop-color="#E8673A" stop-opacity="0"/></radialGradient>
              <radialGradient id="hgb"><stop offset="0%" stop-color="#7C3AED" stop-opacity=".4"/><stop offset="100%" stop-color="#7C3AED" stop-opacity="0"/></radialGradient>
              <filter id="hds"><feDropShadow dx="0" dy="2" stdDeviation="4" flood-color="rgba(0,0,0,.2)"/></filter>
            </defs>
            <!-- Quadrant fills: W top-left, X top-right, Y bottom-left, Z bottom-right -->
            <rect x="28" y="20" width="172" height="142" rx="10" fill="url(#hgW)"/>
            <rect x="204" y="20" width="172" height="142" rx="10" fill="url(#hgX)"/>
            <rect x="28" y="166" width="172" height="142" rx="10" fill="url(#hgY)"/>
            <rect x="204" y="166" width="172" height="142" rx="10" fill="url(#hgZ)"/>
            <!-- Border -->
            <rect x="28" y="20" width="348" height="288" rx="10" fill="none" stroke="#D8D0C8" stroke-width="1.2"/>
            <!-- Centre lines -->
            <line x1="202" y1="20" x2="202" y2="308" stroke="white" stroke-width="3"/>
            <line x1="28" y1="164" x2="376" y2="164" stroke="white" stroke-width="3"/>
            <line x1="202" y1="20" x2="202" y2="308" stroke="#C8C0B8" stroke-width=".8"/>
            <line x1="28" y1="164" x2="376" y2="164" stroke="#C8C0B8" stroke-width=".8"/>
            <!-- Type labels -->
            <text x="42" y="42" font-size="11" font-weight="800" fill="#E8673A" font-family="Georgia,serif" opacity=".9">W</text>
            <text x="42" y="56" font-size="8.5" font-weight="700" fill="#E8673A" font-family="Arial" opacity=".75">The Reacher</text>
            <text x="362" y="42" font-size="11" font-weight="800" fill="#1B5FE8" font-family="Georgia,serif" text-anchor="end" opacity=".9">X</text>
            <text x="362" y="56" font-size="8.5" font-weight="700" fill="#1B5FE8" font-family="Arial" text-anchor="end" opacity=".75">The Driver</text>
            <text x="42" y="290" font-size="11" font-weight="800" fill="#7C3AED" font-family="Georgia,serif" opacity=".9">Y</text>
            <text x="42" y="304" font-size="8.5" font-weight="700" fill="#7C3AED" font-family="Arial" opacity=".75">The Feeler</text>
            <text x="362" y="290" font-size="11" font-weight="800" fill="#6B7280" font-family="Georgia,serif" text-anchor="end" opacity=".9">Z</text>
            <text x="362" y="304" font-size="8.5" font-weight="700" fill="#6B7280" font-family="Arial" text-anchor="end" opacity=".75">The Undercurrent</text>
            <!-- Axis labels -->
            <text x="202" y="12" font-size="9" font-weight="700" fill="#8C7A68" font-family="Arial" text-anchor="middle">Engage</text>
            <text x="202" y="322" font-size="9" font-weight="700" fill="#8C7A68" font-family="Arial" text-anchor="middle">Withdraw</text>
            <text x="18" y="167" font-size="9" font-weight="700" fill="#8C7A68" font-family="Arial" text-anchor="end">Open</text>
            <text x="385" y="167" font-size="9" font-weight="700" fill="#8C7A68" font-family="Arial" text-anchor="start">Guarded</text>
            <!-- Dashed connector: Sarah W(top-left) → James Y(bottom-left) -->
            <line x1="114" y1="80" x2="118" y2="238" stroke="#C0B8B0" stroke-width="1.5" stroke-dasharray="5,4" opacity=".7"/>
            <!-- Sarah dot (W - top-left, open+engage) -->
            <circle cx="114" cy="80" r="28" fill="url(#hga)"/>
            <circle cx="114" cy="80" r="17" fill="none" stroke="#E8673A" stroke-width="1.2" opacity=".3"/>
            <circle cx="114" cy="80" r="11" fill="#E8673A" filter="url(#hds)"/>
            <circle cx="114" cy="80" r="11" fill="none" stroke="white" stroke-width="2"/>
            <circle cx="110" cy="76" r="3.5" fill="white" opacity=".4"/>
            <!-- Sarah tag -->
            <rect x="82" y="55" width="46" height="17" rx="8.5" fill="#E8673A"/>
            <text x="105" y="67" font-size="8.5" font-weight="700" fill="white" text-anchor="middle" font-family="Arial">Sarah</text>
            <polygon points="105,72 101,67 109,67" fill="#E8673A"/>
            <!-- James dot (Y - bottom-left, open+withdraw) -->
            <circle cx="118" cy="238" r="28" fill="url(#hgb)"/>
            <circle cx="118" cy="238" r="17" fill="none" stroke="#7C3AED" stroke-width="1.2" opacity=".3"/>
            <circle cx="118" cy="238" r="11" fill="#7C3AED" filter="url(#hds)"/>
            <circle cx="118" cy="238" r="11" fill="none" stroke="white" stroke-width="2"/>
            <circle cx="114" cy="234" r="3.5" fill="white" opacity=".4"/>
            <!-- James tag -->
            <rect x="84" y="252" width="48" height="17" rx="8.5" fill="#7C3AED"/>
            <text x="108" y="264" font-size="8.5" font-weight="700" fill="white" text-anchor="middle" font-family="Arial">James</text>
            <polygon points="108,252 104,246 112,246" fill="#7C3AED"/>
          </svg>
        </div>
        <!-- Legend + callout -->
        <div style="display:flex;gap:.85rem;margin-top:.5rem;flex-wrap:wrap;">
          <div style="display:flex;align-items:center;gap:.35rem;"><div style="width:8px;height:8px;border-radius:50%;background:#E8673A;"></div><span style="font-size:.62rem;font-weight:600;color:#0E0B07;font-family:'DM Sans',sans-serif;">Sarah · W — The Reacher</span></div>
          <div style="display:flex;align-items:center;gap:.35rem;"><div style="width:8px;height:8px;border-radius:50%;background:#7C3AED;"></div><span style="font-size:.62rem;font-weight:600;color:#0E0B07;font-family:'DM Sans',sans-serif;">James · Y — The Feeler</span></div>
        </div>
        <div style="margin-top:.65rem;padding:.6rem .75rem;background:#FBF8F3;border:1.5px solid #E8DDD0;border-radius:8px;display:flex;align-items:flex-start;gap:.5rem;">
          <div style="width:18px;height:18px;border-radius:50%;background:linear-gradient(135deg,#E8673A,#1B5FE8);flex-shrink:0;display:flex;align-items:center;justify-content:center;margin-top:1px;">
            <svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round"><circle cx="12" cy="12" r="9"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
          </div>
          <p style="font-size:.62rem;color:#8C7A68;line-height:1.55;margin:0;font-weight:300;font-family:'DM Sans',sans-serif;"><strong style="color:#0E0B07;font-weight:700;">Each dot is placed by calculation, not intuition.</strong> These positions are derived from 50 independent questions — you can't guess your way here.</p>
        </div>
      </div>

      <!-- Animated gap card — cycles Conflict / Stress / Repair at 4.5s -->
      <div id="gap-card" style="background:linear-gradient(150deg,#1e1a42,#2c2860);border-radius:20px;overflow:hidden;position:relative;opacity:1;transition:opacity 0.4s ease;height:188px;display:flex;flex-direction:column;">
        <div id="gap-bar" style="height:3px;background:linear-gradient(90deg,#1B5FE8,#1B5FE844);transition:background 0.5s ease;flex-shrink:0;"></div>
        <div style="padding:1.75rem 1.75rem 1rem;flex:1;overflow:hidden;">
          <div id="gap-dim" style="font-size:.52rem;letter-spacing:.22em;text-transform:uppercase;color:rgba(255,255,255,.32);font-family:'DM Sans',sans-serif;font-weight:700;margin-bottom:1.25rem;">Conflict style</div>
          <!-- Fixed height so card never resizes between slides -->
          <div style="display:grid;grid-template-columns:1fr 40px 1fr;align-items:start;">
            <div>
              <div style="font-size:.52rem;letter-spacing:.16em;text-transform:uppercase;color:rgba(232,103,58,.7);font-family:'DM Sans',sans-serif;font-weight:700;margin-bottom:.55rem;">Sarah</div>
              <div id="her-answer" style="font-family:'Playfair Display',Georgia,serif;font-size:1.15rem;font-weight:700;color:white;line-height:1.25;margin-bottom:.4rem;">Address it now.</div>
              <div id="her-sub" style="font-size:.7rem;color:rgba(255,255,255,.45);font-family:'DM Sans',sans-serif;line-height:1.5;">Unresolved things sit heavily with her.</div>
            </div>
            <div style="display:flex;flex-direction:column;align-items:center;padding-top:.25rem;">
              <div style="width:1px;flex:1;background:rgba(255,255,255,.08);min-height:12px;"></div>
              <div id="gap-pill" style="width:28px;height:28px;border-radius:50%;background:rgba(27,95,232,.25);border:1px solid rgba(27,95,232,.4);display:flex;align-items:center;justify-content:center;margin:8px 0;flex-shrink:0;transition:background 0.5s,border-color 0.5s;">
                <span style="font-size:.55rem;color:rgba(255,255,255,.5);font-weight:700;font-family:'DM Sans',sans-serif;">vs</span>
              </div>
              <div style="width:1px;flex:1;background:rgba(255,255,255,.08);min-height:12px;"></div>
            </div>
            <div>
              <div style="font-size:.52rem;letter-spacing:.16em;text-transform:uppercase;color:rgba(27,95,232,.8);font-family:'DM Sans',sans-serif;font-weight:700;margin-bottom:.55rem;">James</div>
              <div id="his-answer" style="font-family:'Playfair Display',Georgia,serif;font-size:1.15rem;font-weight:700;color:white;line-height:1.25;margin-bottom:.4rem;">Needs space first.</div>
              <div id="his-sub" style="font-size:.7rem;color:rgba(255,255,255,.45);font-family:'DM Sans',sans-serif;line-height:1.5;">He can't engage until he's regulated.</div>
            </div>
          </div>
        </div>
        <div style="padding:.5rem 1.75rem .9rem;display:flex;align-items:center;gap:.5rem;flex-shrink:0;">
          <div class="gap-dot" style="width:22px;height:4px;border-radius:2px;background:rgba(255,255,255,.55);transition:all 0.4s;"></div>
          <div class="gap-dot" style="width:8px;height:4px;border-radius:2px;background:rgba(255,255,255,.18);transition:all 0.4s;"></div>
          <div class="gap-dot" style="width:8px;height:4px;border-radius:2px;background:rgba(255,255,255,.18);transition:all 0.4s;"></div>
          <div style="margin-left:auto;font-size:.58rem;color:rgba(255,255,255,.18);font-family:'DM Sans',sans-serif;letter-spacing:.06em;">built from their answers</div>
        </div>
      </div>

    </div>
  </div>
</div>
<script>
(function() {
  var slides = [
    { dim:"Conflict style", her:{ answer:"Address it now.", sub:"Unresolved things sit heavily with her." }, his:{ answer:"Needs space first.", sub:"He can't engage until he's regulated." }, color:"#1B5FE8" },
    { dim:"Under stress",   her:{ answer:"Reaches for closeness.", sub:"Difficulty makes her want more connection." }, his:{ answer:"Pulls inward.", sub:"He needs to be alone to recover." }, color:"#9B5DE5" },
    { dim:"How you repair", her:{ answer:"Needs the words.", sub:"She needs the explicit conversation to close." }, his:{ answer:"Warmth is enough.", sub:"Once the tension lifts, he's already moved on." }, color:"#E8673A" }
  ];
  var cur = 0;
  function goTo(i) {
    var card = document.getElementById('gap-card');
    if (!card) return;
    card.style.opacity = '0';
    setTimeout(function() {
      var s = slides[i];
      document.getElementById('gap-dim').textContent = s.dim;
      document.getElementById('her-answer').textContent = s.her.answer;
      document.getElementById('her-sub').textContent = s.her.sub;
      document.getElementById('his-answer').textContent = s.his.answer;
      document.getElementById('his-sub').textContent = s.his.sub;
      document.getElementById('gap-bar').style.background = 'linear-gradient(90deg,'+s.color+','+s.color+'44)';
      document.getElementById('gap-pill').style.background = s.color+'28';
      document.getElementById('gap-pill').style.borderColor = s.color+'55';
      document.querySelectorAll('.gap-dot').forEach(function(d,j){
        d.style.width=j===i?'22px':'8px';
        d.style.background=j===i?'rgba(255,255,255,.55)':'rgba(255,255,255,.18)';
      });
      card.style.opacity = '1';
    }, 400);
  }
  /* Also animate the mobile gap strip */
  function goToMobile(i) {
    var s = slides[i];
    var bar  = document.getElementById('hgs-bar');
    var her  = document.getElementById('hgs-her');
    var his  = document.getElementById('hgs-his');
    var pill = document.getElementById('hgs-pill');
    var dim  = document.getElementById('hgs-dim');
    var dots = document.getElementById('hgs-dots');
    if (!bar) return;
    bar.style.background  = 'linear-gradient(90deg,'+s.color+','+s.color+'44)';
    pill.style.background = s.color+'25';
    pill.style.borderColor= s.color+'45';
    her.textContent  = s.her.answer;
    his.textContent  = s.his.answer;
    dim.textContent  = s.dim;
    if (dots) dots.querySelectorAll('div').forEach(function(d,j){
      d.style.width      = j===i ? '12px' : '4px';
      d.style.background = j===i ? 'rgba(255,255,255,.4)' : 'rgba(255,255,255,.15)';
    });
  }
  setInterval(function(){ cur=(cur+1)%slides.length; goTo(cur); goToMobile(cur); }, 4500);
})();
</script>

<!-- WHAT YOU LEARN -->
<section>
  <div class="si">
    <!-- Simple header before cards -->
    <div style="text-align:center;margin-bottom:2.5rem;border-top:1.5px solid var(--stone);padding-top:3rem;">
      <div style="display:inline-flex;align-items:center;gap:.75rem;font-size:.6rem;letter-spacing:.28em;text-transform:uppercase;color:var(--clay);font-weight:700;margin-bottom:.85rem;">
        <span style="width:20px;height:1.5px;background:var(--clay);display:inline-block;"></span>
        What your results look like
        <span style="width:20px;height:1.5px;background:var(--clay);display:inline-block;"></span>
      </div>
      <h2 style="font-family:var(--hfont);font-size:clamp(1.6rem,3vw,2.2rem);font-weight:700;color:var(--ink);line-height:1.1;letter-spacing:-.02em;margin:0 auto;max-width:520px;">Built from your answers. Specific to you two.</h2>
    </div>

    <!-- Story cards row -->
    <div class="story-cards story-cards-desktop" style="display:grid;grid-template-columns:repeat(3,1fr);gap:1.25rem;align-items:stretch;">

      <!-- Card 1: Couple Type -->
      <div style="background:linear-gradient(160deg,#2d1240,#461860,#2d1240);border-radius:20px;overflow:hidden;display:flex;flex-direction:column;position:relative;min-height:420px;">
        <div style="height:3px;background:linear-gradient(90deg,#E91E63,#9C27B0);flex-shrink:0;"></div>
        <div style="position:absolute;top:14px;left:16px;display:flex;align-items:center;gap:4px;opacity:.35;">
          <svg width="14" height="10" viewBox="0 0 103 76" fill="none"><defs><linearGradient id="sg1" x1="0" y1="0" x2="103" y2="76" gradientUnits="userSpaceOnUse"><stop offset="0%" stop-color="#E8673A"/><stop offset="100%" stop-color="#1B5FE8"/></linearGradient></defs><path d="M14,4 L44,4 A9,9 0 0,1 53,13 L53,42 A9,9 0 0,1 44,51 L20,51 L6,61 L11,51 A6,6 0 0,1 5,45 L5,13 A9,9 0 0,1 14,4 Z" fill="url(#sg1)"/><path d="M22 11 C20 8.5 16.5 5 11.5 5 C5.5 5 2 9.5 2 14.5 C2 23 11 30 22 40 C33 30 42 23 42 14.5 C42 9.5 38.5 5 32.5 5 C27.5 5 24 8.5 22 11 Z" fill="white" opacity=".9" transform="translate(13.16,11.3) scale(0.72)"/><path d="M89,14 L59,14 A9,9 0 0,0 50,23 L50,52 A9,9 0 0,0 59,61 L83,61 L97,71 L92,61 A6,6 0 0,0 98,55 L98,23 A9,9 0 0,0 89,14 Z" fill="none" stroke="url(#sg1)" stroke-width="2.2" stroke-linejoin="round"/><path d="M22 11 C20 8.5 16.5 5 11.5 5 C5.5 5 2 9.5 2 14.5 C2 23 11 30 22 40 C33 30 42 23 42 14.5 C42 9.5 38.5 5 32.5 5 C27.5 5 24 8.5 22 11 Z" fill="url(#sg1)" transform="translate(58.16,21.3) scale(0.72)"/></svg>
          <span style="font-family:'Playfair Display',Georgia,serif;font-size:.58rem;font-weight:700;color:white;">Attune</span>
        </div>
        <div style="padding:2.25rem 1.75rem 2rem;flex:1;display:flex;flex-direction:column;justify-content:space-between;">
          <div>
            <div style="font-size:.52rem;letter-spacing:.24em;text-transform:uppercase;color:rgba(233,30,99,.65);font-weight:700;margin-bottom:1.25rem;font-family:'DM Sans',sans-serif;">Couple Type</div>
            <div style="font-family:'Playfair Display',Georgia,serif;font-size:2.5rem;font-weight:700;color:white;line-height:.95;margin-bottom:.75rem;letter-spacing:-.02em;">The Mismatch</div>
            <p style="font-size:.82rem;color:#E91E63;font-weight:600;line-height:1.45;margin:0;font-family:'DM Sans',sans-serif;">Different conflict clocks. Knowing that changes everything.</p>
          </div>
          <!-- Mini 2x2 couple map -->
          <div style="margin-top:1.25rem;">
            <div style="position:relative;width:100%;height:96px;border-radius:10px;overflow:hidden;margin-bottom:.85rem;">
              <!-- Quadrant grid -->
              <div style="display:grid;grid-template-columns:1fr 1fr;grid-template-rows:1fr 1fr;width:100%;height:100%;gap:2px;">
                <div style="background:rgba(232,103,58,.55);border-radius:5px 0 0 0;display:flex;align-items:flex-start;padding:5px 6px;font-size:.5rem;font-weight:700;color:rgba(255,255,255,.9);font-family:'DM Sans',sans-serif;">W</div>
                <div style="background:rgba(27,95,232,.48);border-radius:0 5px 0 0;display:flex;align-items:flex-start;justify-content:flex-end;padding:5px 6px;font-size:.5rem;font-weight:700;color:rgba(255,255,255,.9);font-family:'DM Sans',sans-serif;">X</div>
                <div style="background:rgba(124,58,237,.48);border-radius:0 0 0 5px;display:flex;align-items:flex-end;padding:5px 6px;font-size:.5rem;font-weight:700;color:rgba(255,255,255,.9);font-family:'DM Sans',sans-serif;">Y</div>
                <div style="background:rgba(107,114,128,.38);border-radius:0 0 5px 0;display:flex;align-items:flex-end;justify-content:flex-end;padding:5px 6px;font-size:.5rem;font-weight:700;color:rgba(255,255,255,.75);font-family:'DM Sans',sans-serif;">Z</div>
              </div>
              <!-- White centre lines -->
              <div style="position:absolute;top:0;bottom:0;left:50%;width:2px;background:rgba(255,255,255,.25);transform:translateX(-50%);"></div>
              <div style="position:absolute;left:0;right:0;top:50%;height:2px;background:rgba(255,255,255,.25);transform:translateY(-50%);"></div>
              <!-- Sarah dot: W quadrant (top-left) -->
              <div style="position:absolute;left:28%;top:28%;width:13px;height:13px;border-radius:50%;background:#E8673A;box-shadow:0 0 0 4px rgba(232,103,58,.3),0 2px 6px rgba(0,0,0,.25);border:2px solid rgba(255,255,255,.8);transform:translate(-50%,-50%);"></div>
              <!-- James dot: Y quadrant (bottom-left) -->
              <div style="position:absolute;left:30%;top:72%;width:13px;height:13px;border-radius:50%;background:#7C3AED;box-shadow:0 0 0 4px rgba(124,58,237,.3),0 2px 6px rgba(0,0,0,.25);border:2px solid rgba(255,255,255,.8);transform:translate(-50%,-50%);"></div>
              <!-- Dashed line -->
              <svg style="position:absolute;inset:0;width:100%;height:100%;overflow:visible;" viewBox="0 0 100 100" preserveAspectRatio="none">
                <line x1="28" y1="28" x2="30" y2="72" stroke="rgba(255,255,255,.35)" stroke-width="1.5" stroke-dasharray="3,2.5"/>
              </svg>
            </div>
            <div style="display:flex;gap:1rem;align-items:center;">
              <div style="display:flex;align-items:center;gap:.4rem;"><div style="width:8px;height:8px;border-radius:50%;background:#E8673A;box-shadow:0 0 0 2px rgba(232,103,58,.3);flex-shrink:0;"></div><span style="font-size:.6rem;color:rgba(255,255,255,.55);font-family:'DM Sans',sans-serif;font-weight:600;">Sarah · W — The Reacher</span></div>
              <div style="display:flex;align-items:center;gap:.4rem;"><div style="width:8px;height:8px;border-radius:50%;background:#7C3AED;box-shadow:0 0 0 2px rgba(124,58,237,.3);flex-shrink:0;"></div><span style="font-size:.6rem;color:rgba(255,255,255,.75);font-family:'DM Sans',sans-serif;font-weight:600;">James · Y — The Feeler</span></div>
            </div>
          </div>
        </div>
      </div>

      <!-- Card 2: Communication -->
      <div style="background:linear-gradient(160deg,#0d2c24,#163d30,#0d2c24);border-radius:20px;overflow:hidden;display:flex;flex-direction:column;position:relative;min-height:420px;">
        <div style="height:3px;background:linear-gradient(90deg,#34d399,rgba(52,211,153,.3));flex-shrink:0;"></div>
        <div style="position:absolute;top:14px;left:16px;display:flex;align-items:center;gap:4px;opacity:.35;">
          <svg width="14" height="10" viewBox="0 0 103 76" fill="none"><use href="#sg1"/></svg>
          <span style="font-family:'Playfair Display',Georgia,serif;font-size:.58rem;font-weight:700;color:white;">Attune</span>
        </div>
        <div style="padding:2.25rem 1.75rem 2rem;flex:1;display:flex;flex-direction:column;justify-content:space-between;">
          <div>
            <div style="font-size:.52rem;letter-spacing:.24em;text-transform:uppercase;color:rgba(232,103,58,1);font-weight:700;margin-bottom:1.25rem;font-family:'DM Sans',sans-serif;">Communication</div>
            <div style="font-family:'Playfair Display',Georgia,serif;font-size:1.75rem;font-weight:700;color:white;line-height:1.05;margin-bottom:.75rem;">How you each actually show up.</div>
            <div style="display:flex;flex-direction:column;gap:.5rem;">
              <div style="display:flex;align-items:center;gap:.6rem;">
                <span style="font-size:.65rem;color:#E8673A;font-weight:700;width:40px;flex-shrink:0;font-family:'DM Sans',sans-serif;">Sarah</span>
                <div style="flex:1;background:rgba(255,255,255,.08);border-radius:3px;height:5px;overflow:hidden;"><div style="background:#E8673A;height:5px;width:15%;border-radius:3px;"></div></div>
