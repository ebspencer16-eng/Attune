<!-- SOCIAL PROOF -->
<section class="proof-section">
  <div class="proof-inner">
    <p class="s-eye">What couples are saying</p>

    <!-- Single animated quote — cycles every 6 seconds -->
    <div style="max-width:680px;margin:2.5rem auto 0;position:relative;height:190px;overflow:hidden;">
      <div id="quote-display" style="transition:opacity .45s ease;">
        <div class="proof-stars" style="margin-bottom:1rem;">★★★★★</div>
        <p id="quote-text" class="proof-text" style="font-size:1.15rem;max-width:600px;"></p>
        <div class="proof-person" style="margin-top:1.25rem;">
          <div>
            <div id="quote-name" class="proof-name"></div>
            <div id="quote-detail" class="proof-detail"></div>
          </div>
        </div>
      </div>
      <!-- Dot nav -->
      <div style="display:flex;gap:.55rem;margin-top:1.75rem;" id="quote-dots">
        <div style="width:20px;height:3px;border-radius:2px;background:var(--ink);opacity:.55;cursor:pointer;transition:all .3s;" onclick="showQuote(0)"></div>
        <div style="width:6px;height:3px;border-radius:2px;background:var(--stone);cursor:pointer;transition:all .3s;" onclick="showQuote(1)"></div>
        <div style="width:6px;height:3px;border-radius:2px;background:var(--stone);cursor:pointer;transition:all .3s;" onclick="showQuote(2)"></div>
      </div>
    </div>

    <div class="proof-stat-row">
      <div class="proof-stat">
        <div class="proof-stat-num">2,400+</div>
        <div class="proof-stat-label">Couples completed</div>
      </div>
      <div class="proof-stat">
        <div class="proof-stat-num">4.9</div>
        <div class="proof-stat-label">Average rating</div>
      </div>
      <div class="proof-stat">
        <div class="proof-stat-num">73%</div>
        <div class="proof-stat-label">Say they learned something surprising</div>
      </div>
      <div class="proof-stat">
        <div class="proof-stat-num">91%</div>
        <div class="proof-stat-label">Would recommend to a friend</div>
      </div>
    </div>
  </div>
</section>
<script>
(function(){
  var quotes = [
    { text: "“I thought I knew James pretty well after four years. Attune showed me there were things we'd just never thought to ask each other. The expectations comparison alone was worth it.”", name: "Sarah M.", detail: "Together 4 years · Anniversary package" },
    { text: "“We're getting married in three months and this was the best pre-wedding thing we did. Way more useful than premarital counseling worksheets. We actually learned something new.”", name: "Alex & Jordan T.", detail: "Engaged · Starting Out package" },
    { text: "“The LMFT session was what made it. She'd read our results beforehand and came prepared with actual observations about us specifically. Not generic advice, our stuff.”", name: "Maya & Chris R.", detail: "Married 7 years · Premium package" },
  ];
  var cur = 0;
  window.showQuote = function(i) {
    var d = document.getElementById('quote-display');
    d.style.opacity = '0';
    setTimeout(function(){
      cur = i;
      document.getElementById('quote-text').textContent = quotes[i].text;
      document.getElementById('quote-name').textContent = quotes[i].name;
      document.getElementById('quote-detail').textContent = quotes[i].detail;
      var dots = document.getElementById('quote-dots').children;
      for(var j=0;j<dots.length;j++){
        dots[j].style.width = j===i?'20px':'6px';
        dots[j].style.background = j===i?'var(--ink)':'var(--stone)';
        dots[j].style.opacity = j===i?'.55':'1';
      }
      d.style.opacity = '1';
    }, 420);
  };
  showQuote(0);
  setInterval(function(){ showQuote((cur+1)%quotes.length); }, 6000);
})();
</script>

