          <div style="margin-top:1.25rem;font-size:.65rem;color:rgba(255,255,255,.4);font-family:'DM Sans',sans-serif;">10 dimensions, side by side</div>
        </div>
      </div>

      <!-- Card 3 clone: Expectations -->
      <div style="background:linear-gradient(160deg,#122d58,#183e82,#122d58);border-radius:20px;overflow:hidden;display:flex;flex-direction:column;position:relative;min-height:320px;min-width:calc(85vw - 1rem);max-width:320px;flex-shrink:0;scroll-snap-align:start;margin-right:1.25rem;">
        <div style="height:3px;background:linear-gradient(90deg,#1B5FE8,#1B5FE855);flex-shrink:0;"></div>
        <div style="padding:1.75rem 1.5rem 1.5rem;flex:1;display:flex;flex-direction:column;justify-content:space-between;">
          <div>
            <div style="font-size:.5rem;letter-spacing:.22em;text-transform:uppercase;color:rgba(27,95,232,1);font-weight:700;margin-bottom:1rem;font-family:'DM Sans',sans-serif;">Expectations</div>
            <div style="font-family:'Playfair Display',Georgia,serif;font-size:4rem;font-weight:700;color:white;line-height:.9;letter-spacing:-.03em;margin-bottom:.4rem;">28%</div>
            <div style="font-size:.85rem;color:rgba(255,255,255,.82);font-family:'DM Sans',sans-serif;font-weight:300;margin-bottom:1rem;">aligned on expectations</div>
          </div>
          <div style="margin-top:1.25rem;font-size:.65rem;color:rgba(255,255,255,.4);font-family:'DM Sans',sans-serif;">What you each assumed. Now visible.</div>
        </div>
      </div>

    </div>
    <!-- Mobile scroll indicator dots -->
    <div class="story-cards-mobile-scroll" style="display:none;align-items:center;gap:.4rem;margin-top:.6rem;padding-left:1.25rem;">
