<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

<link rel="manifest" href="/manifest.json">
  <meta name="theme-color" content="#0E0B07">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Attune, Understand each other deeply. And how to grow together.</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,800;1,700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
  :root{
    --cream:#FFFDF9;--warm:#FBF8F3;--stone:#E8DDD0;
    --clay:#C17F47;--ink:#0E0B07;--text:#1E1610;--muted:#8C7A68;
    --orange:#E8673A;--indigo:#1B5FE8;
    --hfont:'Playfair Display',Georgia,serif;
    --bfont:'DM Sans',sans-serif;
  }
  html{scroll-behavior:smooth}
  html,body{overflow-x:hidden;max-width:100%}
  body{background:var(--cream);color:var(--text);font-family:var(--bfont);-webkit-font-smoothing:antialiased}

  /* NAV */
  nav{position:fixed;top:0;left:0;right:0;z-index:100;height:58px;background:rgba(255,253,249,.94);backdrop-filter:blur(16px);border-bottom:1px solid var(--stone);display:flex;align-items:center;padding:0 2.5rem;justify-content:space-between}
  .logo{display:flex;align-items:center;gap:.65rem;text-decoration:none}
  .logo-mark{display:flex;align-items:center;flex-shrink:0}
  .logo-text{font-family:var(--hfont);font-size:1.15rem;font-weight:700;color:var(--ink)}
  .nav-center{display:flex;gap:2.5rem;list-style:none;position:absolute;left:50%;transform:translateX(-50%);align-items:center}.nav-center li{display:flex;align-items:center}
  .nav-center a{text-decoration:none;color:var(--muted);font-size:.82rem;font-weight:500;transition:color .15s}
  .nav-center a:hover{color:var(--ink)}
  /* LEARN DROPDOWN */
  .nav-dropdown{position:relative}
  .nav-dropdown-toggle{text-decoration:none;color:var(--muted);font-size:.82rem;font-weight:500;transition:color .15s;cursor:pointer;display:flex;align-items:center;gap:.28rem;background:none;border:none;padding:0;font-family:var(--bfont)}
  .nav-dropdown-toggle:hover,.nav-dropdown-toggle.active{color:var(--ink)}
  .nav-dropdown-toggle svg{transition:transform .2s}
  .nav-dropdown:hover .nav-dropdown-toggle svg{transform:rotate(180deg)}
  .nav-dropdown-menu{position:absolute;top:100%;left:50%;transform:translateX(-50%);background:rgba(255,253,249,.98);backdrop-filter:blur(16px);border:1.5px solid var(--stone);border-radius:14px;padding:.6rem;min-width:190px;opacity:0;visibility:hidden;pointer-events:none;transition:opacity .15s,visibility .15s;box-shadow:0 12px 40px rgba(14,11,7,.12);z-index:200;margin-top:0}
  .nav-dropdown:hover .nav-dropdown-menu{opacity:1;visibility:visible;pointer-events:auto}
  .nav-dropdown-menu::before{content:'';position:absolute;top:-16px;left:-10px;right:-10px;height:16px;background:transparent;}
  .nav-dropdown-menu a{display:block;padding:.55rem .8rem;font-size:.78rem;color:var(--muted);text-decoration:none;border-radius:8px;transition:all .15s;font-weight:500}
  .nav-dropdown-menu a:hover{background:var(--warm);color:var(--ink)}
  .nav-dropdown-menu .dd-divider{height:1px;background:var(--stone);margin:.35rem .5rem}
  .nav-center a.active{color:var(--ink);font-weight:600}
  .nav-right{display:flex;align-items:center;gap:1.25rem}
  .nav-signin{font-size:.8rem;font-weight:500;color:var(--muted);text-decoration:none;transition:color .15s}
  .nav-signin:hover{color:var(--ink)}
  .btn-nav{background:var(--ink);color:white;padding:.5rem 1.2rem;border-radius:10px;font-size:.78rem;font-weight:600;text-decoration:none;display:inline-block;transition:opacity .15s}
  .btn-nav:hover{opacity:.82}

  /* HERO */
  .hero{padding-top:58px;min-height:100vh;display:grid;grid-template-columns:1fr 1.15fr;align-items:stretch;max-width:1280px;margin:0 auto;padding-left:3.5rem;padding-right:3.5rem;gap:6rem;position:relative;overflow:visible}
  .hero-blobs{position:absolute;top:-200px;left:-200px;right:-200px;bottom:-200px;pointer-events:none;z-index:0;overflow:visible}
  .hero-blob{position:absolute;border-radius:50%;}
  .hero-left,.hero-right{position:relative;z-index:1}
  .hero-right{display:flex;flex-direction:column;padding:5.5rem 0 4rem;}
  .hero-left{padding:3.5rem 0 3rem;display:flex;flex-direction:column;justify-content:center;}
  .eyebrow{display:inline-flex;align-items:center;gap:.5rem;font-size:.62rem;letter-spacing:.3em;text-transform:uppercase;color:var(--clay);font-weight:700;margin-bottom:1.5rem;white-space:nowrap}
  .eyebrow-dot{width:5px;height:5px;border-radius:50%;background:var(--orange)}
  h1{font-family:var(--hfont);font-size:clamp(2.6rem,4.2vw,3.7rem);font-weight:700;line-height:1.06;color:var(--ink);margin-bottom:1.6rem;letter-spacing:-.02em}
  h1 em{font-style:italic;color:var(--orange)}
  .hero-sub{font-size:1.02rem;color:var(--muted);line-height:1.78;max-width:430px;margin-bottom:1.75rem;font-weight:300}
  /* for-you / gift toggle */
  .use-toggle{display:flex;gap:.75rem;margin-bottom:2.5rem}
  .use-btn{padding:.55rem 1.1rem;border-radius:10px;font-size:.78rem;font-weight:600;cursor:pointer;border:1.5px solid var(--stone);background:white;color:var(--muted);font-family:var(--bfont);transition:all .15s;display:flex;align-items:center;gap:.45rem}
  .use-btn.active{background:var(--ink);color:white;border-color:var(--ink)}
  .use-btn svg{width:14px;height:14px;flex-shrink:0}
  .use-desc{font-size:.82rem;color:var(--muted);line-height:1.65;margin-bottom:2.25rem;min-height:2.5rem;transition:opacity .2s}
  .hero-actions{display:flex;align-items:center;gap:1.25rem}
  .btn-primary{background:linear-gradient(135deg,var(--orange),#d45a2e);color:white;border:none;padding:.9rem 2.1rem;border-radius:12px;font-size:.82rem;font-weight:700;letter-spacing:.05em;text-transform:uppercase;cursor:pointer;font-family:var(--bfont);text-decoration:none;display:inline-block;box-shadow:0 6px 24px rgba(232,103,58,.38);transition:transform .18s,box-shadow .18s}
  .btn-primary:hover{transform:translateY(-2px);box-shadow:0 10px 30px rgba(232,103,58,.45)}
  .btn-ghost{font-size:.82rem;font-weight:500;color:var(--muted);text-decoration:none;display:inline-flex;align-items:center;gap:.35rem;transition:color .15s}
  .btn-ghost:hover{color:var(--ink)}
  .hero-proof{margin-top:2rem;display:flex;align-items:center;gap:.75rem;font-size:.75rem;color:var(--muted)}
  .proof-dot{width:7px;height:7px;border-radius:50%;background:#3dba7a;flex-shrink:0}

  /* HERO CARD */
  .hero-card{background:linear-gradient(150deg,#1e1a48,#2e2a68 50%,#201d52);border-radius:22px;padding:2rem;color:white;position:relative;overflow:hidden;box-shadow:0 32px 80px rgba(14,11,7,.22),0 0 0 1px rgba(255,255,255,.06)}
  .hero-card::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:linear-gradient(90deg,var(--orange),var(--indigo))}
  .hc-label{font-size:.56rem;letter-spacing:.3em;text-transform:uppercase;color:rgba(232,103,58,.65);margin-bottom:.3rem}
  .hc-names{font-family:var(--hfont);font-size:1.85rem;font-weight:700;margin-bottom:.6rem;letter-spacing:-.02em}
  .hc-badge{display:inline-block;background:rgba(255,255,255,.11);border:1px solid rgba(255,255,255,.18);padding:.28rem .75rem;border-radius:999px;font-size:.68rem;font-weight:600;margin-bottom:.9rem}
  .hc-stats{display:flex;gap:.5rem;flex-wrap:wrap;margin-bottom:1.1rem}
  .hc-stat{background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.12);padding:.22rem .65rem;border-radius:999px;font-size:.62rem;color:rgba(255,255,255,.65)}
  .hc-profiles{display:grid;grid-template-columns:1fr 1fr;gap:.65rem;margin-bottom:1.25rem}
  .hc-profile{border-radius:10px;padding:.75rem .9rem}
  .hc-profile.s{background:rgba(232,103,58,.16);border:1px solid rgba(232,103,58,.28)}
  .hc-profile.j{background:rgba(91,109,248,.16);border:1px solid rgba(91,109,248,.28)}
  .hc-pname{font-size:.53rem;letter-spacing:.2em;text-transform:uppercase;opacity:.5;margin-bottom:.22rem}
  .hc-pdesc{font-size:.76rem;font-weight:500;line-height:1.3}
  /* dimension tiles with explore arrows */
  .hc-dims{display:grid;grid-template-columns:1fr 1fr;gap:.5rem}
  .hc-dim{background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.1);border-radius:9px;padding:.6rem .75rem;display:flex;justify-content:space-between;align-items:center;transition:background .15s}
  .hc-dim:hover{background:rgba(255,255,255,.11)}
  .hc-dim-left{display:flex;align-items:center;gap:.5rem}
  .hc-dim-dot{width:6px;height:6px;border-radius:50%;flex-shrink:0}
  .hc-dim-info{}
  .hc-dim-name{font-size:.62rem;font-weight:600;margin-bottom:.1rem}
  .hc-dim-val{font-size:.55rem;color:rgba(255,255,255,.70)}
  .hc-dim-arrow{color:rgba(255,255,255,.28);font-size:.7rem;flex-shrink:0}

  /* SECTIONS */
  section{padding:6rem 2.5rem}
  .si{max-width:1120px;margin:0 auto}
  .s-eye{font-size:.62rem;letter-spacing:.3em;text-transform:uppercase;color:var(--clay);font-weight:700;margin-bottom:.85rem;display:flex;align-items:center;gap:.5rem}
  .s-eye::before{content:'';width:20px;height:1.5px;background:var(--clay)}
  .s-title{font-family:var(--hfont);font-size:clamp(1.9rem,3.2vw,2.7rem);font-weight:700;line-height:1.1;color:var(--ink);margin-bottom:1.1rem;letter-spacing:-.02em}
  .s-title em{font-style:italic;color:var(--orange)}
  .s-sub{font-size:.95rem;color:var(--muted);line-height:1.78;font-weight:300;max-width:540px}

  /* WHY IT MATTERS, replaces "how it works" */
  .bg-warm{background:var(--warm);border-top:1px solid var(--stone);border-bottom:1px solid var(--stone)}
  .why-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:2rem;margin-top:3.5rem}
  .why-card{background:white;border:1px solid var(--stone);border-radius:18px;padding:1.85rem;transition:box-shadow .22s,transform .22s;position:relative}
  .why-card:hover{box-shadow:0 10px 40px rgba(14,11,7,.09);transform:translateY(-2px)}
  .why-icon-wrap{width:48px;height:48px;border-radius:13px;display:flex;align-items:center;justify-content:center;margin-bottom:1.1rem}
  .why-title{font-size:.98rem;font-weight:700;color:var(--ink);margin-bottom:.55rem}
  .why-desc{font-size:.84rem;color:var(--muted);line-height:1.7}

  /* WHAT YOU LEARN */
  .what-layout{display:grid;grid-template-columns:1fr 1.1fr;gap:6rem;align-items:center;margin-top:3.5rem}
  .what-list{display:flex;flex-direction:column;gap:1.5rem}
  .what-item{display:flex;gap:1.1rem;align-items:flex-start}
  .what-icon-wrap{width:42px;height:42px;border-radius:12px;flex-shrink:0;display:flex;align-items:center;justify-content:center}
  .what-item h4{font-size:.9rem;font-weight:700;color:var(--ink);margin-bottom:.25rem}
  .what-item p{font-size:.82rem;color:var(--muted);line-height:1.65}

  /* results mock */
  .rm{background:var(--warm);border:1px solid var(--stone);border-radius:20px;padding:1.5rem}
  .rm-hdr{display:flex;justify-content:space-between;align-items:center;margin-bottom:1.25rem}
  .rm-lbl{font-size:.6rem;letter-spacing:.22em;text-transform:uppercase;color:var(--clay);font-weight:700}
  .rm-tabs{display:flex;gap:.4rem}
  .rm-tab{padding:.28rem .68rem;border-radius:999px;font-size:.6rem;font-weight:500;border:1.5px solid var(--stone);color:var(--muted)}
  .rm-tab.a{background:var(--ink);color:white;border-color:var(--ink)}
  .rm-hero{background:linear-gradient(150deg,#1e1c42,#2b285c);border-radius:14px;padding:1.25rem;margin-bottom:1rem;color:white}
  .rm-hlbl{font-size:.52rem;letter-spacing:.24em;text-transform:uppercase;color:rgba(232,103,58,.65);margin-bottom:.25rem}
  .rm-hname{font-family:var(--hfont);font-size:1.35rem;font-weight:700;margin-bottom:.45rem}
  .rm-chips{display:flex;gap:.4rem;flex-wrap:wrap;margin-bottom:.6rem}
  .rm-chip{background:rgba(255,255,255,.09);border:1px solid rgba(255,255,255,.13);padding:.18rem .55rem;border-radius:999px;font-size:.59rem;color:rgba(255,255,255,.6)}
  /* dimension tiles in mock, with arrows */
  .rm-grid{display:grid;grid-template-columns:1fr 1fr;gap:.55rem}
  .rm-dim{background:white;border-radius:9px;padding:.7rem .8rem;border:1px solid var(--stone);display:flex;justify-content:space-between;align-items:center;cursor:pointer;transition:border-color .15s,box-shadow .15s}
  .rm-dim:hover{border-color:var(--clay);box-shadow:0 2px 8px rgba(14,11,7,.07)}
  .rm-dim-left{}
  .rm-dlbl{font-size:.58rem;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.08em;margin-bottom:.25rem}
  .rm-dval{font-size:.7rem;color:var(--ink);font-weight:500;display:flex;align-items:center;gap:.35rem}
  .rm-dot{width:6px;height:6px;border-radius:50%;flex-shrink:0}
  .rm-arrow{color:var(--clay);font-size:.85rem;flex-shrink:0;font-weight:600}

  /* WHO IT'S FOR */
  .for-icon-wrap{width:44px;height:44px;border-radius:12px;display:flex;align-items:center;justify-content:center;margin-bottom:1.1rem}

  /* NOT FOR CRISIS, philosophy bar */
  .philosophy-bar{border-top:1px solid var(--stone);border-bottom:1px solid var(--stone);padding:3rem 2.5rem;background:white}
  .pb-inner{max-width:1120px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:center}
  .pb-eyebrow{font-size:.62rem;letter-spacing:.3em;text-transform:uppercase;color:var(--clay);font-weight:700;margin-bottom:.75rem;display:flex;align-items:center;gap:.5rem}
  .pb-eyebrow::before{content:'';width:20px;height:1.5px;background:var(--clay)}
  .pb-title{font-family:var(--hfont);font-size:1.6rem;font-weight:700;line-height:1.2;color:var(--ink);letter-spacing:-.02em}
  .pb-title em{font-style:italic;color:var(--orange)}
  .pb-body{font-size:.88rem;color:var(--muted);line-height:1.78}

  /* DARK PHILOSOPHY */
  .bg-dark{background:linear-gradient(150deg,#1a1740,#252060)}
  .bg-dark .s-eye{color:rgba(232,103,58,.65)}
  .bg-dark .s-eye::before{background:rgba(232,103,58,.4)}
  .bg-dark .s-title{color:white}
  .bg-dark .s-sub{color:rgba(255,255,255,.72)}
  .phil-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem;margin-top:3rem}
  .phil-card{background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.09);border-radius:18px;padding:1.85rem}
  .phil-q{font-family:var(--hfont);font-size:1.05rem;font-style:italic;line-height:1.58;color:rgba(255,255,255,.86);margin-bottom:1.1rem}
  .phil-src{font-size:.7rem;color:rgba(255,255,255,.3)}

  /* SOCIAL PROOF */
  .proof-section{padding:5rem 2.5rem;background:var(--warm)}
  .proof-inner{max-width:1120px;margin:0 auto}
  .proof-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem;margin-top:3rem}
  .proof-card{background:transparent;border:none;padding:1.85rem 1.5rem;position:relative;border-top:1px solid var(--stone)}
  .proof-stars{color:var(--orange);font-size:.65rem;margin-bottom:.85rem;letter-spacing:.2em;opacity:.8}
  .proof-text{font-family:var(--hfont);font-size:1.05rem;font-style:italic;line-height:1.65;color:var(--ink);margin-bottom:1.25rem;padding-top:.35rem}
  .proof-person{display:flex;align-items:center;gap:.65rem}
  .proof-avatar{width:34px;height:34px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:.8rem;font-weight:700;color:white;flex-shrink:0}
  .proof-name{font-size:.78rem;font-weight:700;color:var(--ink);letter-spacing:.03em}
  .proof-detail{font-size:.7rem;color:var(--muted)}
  .proof-stat-row{display:flex;gap:2.5rem;justify-content:center;margin-top:3.5rem;flex-wrap:wrap;padding-top:3rem;border-top:1px solid var(--stone);position:relative}
  .proof-stat-row::before{content:'';position:absolute;top:-1px;left:50%;transform:translateX(-50%);width:80px;height:2px;background:linear-gradient(90deg,var(--orange),var(--indigo));border-radius:999px}
  .proof-stat{text-align:center}
  .proof-stat-num{font-family:var(--hfont);font-size:2.1rem;font-weight:700;color:var(--ink);line-height:1}
  .proof-stat-label{font-size:.72rem;color:var(--muted);margin-top:.3rem;letter-spacing:.04em}

  /* CTA */
  .cta-wrap{text-align:center;padding:3rem 2.5rem}
  .cta-inner{max-width:600px;margin:0 auto}
  .cta-title{font-family:var(--hfont);font-size:clamp(2rem,3.8vw,3rem);font-weight:700;line-height:1.08;color:var(--ink);margin-bottom:1.25rem;letter-spacing:-.02em}
  .cta-title em{font-style:italic;color:var(--orange)}
  .cta-sub{font-size:.96rem;color:var(--muted);line-height:1.78;margin-bottom:2.75rem;font-weight:300}
  .cta-actions{display:flex;justify-content:center;gap:1.25rem;flex-wrap:wrap;align-items:center}

  /* FOOTER */
  .footer-outer{border-top:1px solid var(--stone)}
  footer{max-width:1120px;margin:0 auto;padding:2rem 2.5rem;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1rem}
  .footer-links{display:flex;gap:1.75rem;list-style:none}
  .footer-links a{font-size:.78rem;color:var(--muted);text-decoration:none;transition:color .15s}
  .footer-links a:hover{color:var(--ink)}
  .footer-copy{font-size:.72rem;color:var(--muted)}

  /* ══ SITE FOOTER ══ */
  .site-footer{background:var(--ink);color:rgba(255,255,255,.80);padding:4rem 0 2rem;width:100%;margin-left:0;margin-right:0;max-width:none;display:block}
  .sf-inner{max-width:1120px;margin:0 auto;padding:0 2.5rem 3rem;display:grid;grid-template-columns:1fr 2fr;gap:4rem;border-bottom:1px solid rgba(255,255,255,.1)}
  .sf-brand .logo-text{color:white}
  .sf-tagline{font-size:.82rem;color:rgba(255,255,255,.38);line-height:1.7;margin-top:.85rem;max-width:200px}
  .sf-links{display:grid;grid-template-columns:repeat(3,1fr);gap:2rem}
  .sf-col{display:flex;flex-direction:column;gap:.5rem}
  .sf-col-title{font-size:.62rem;letter-spacing:.22em;text-transform:uppercase;color:rgba(255,255,255,.65);font-weight:700;margin-bottom:.4rem}
  .sf-col a{font-size:.82rem;color:rgba(255,255,255,.80);text-decoration:none;transition:color .15s}
  .sf-col a:hover{color:white}
  .sf-bottom{max-width:1120px;margin:0 auto;padding:1.75rem 2.5rem 0;display:flex;flex-direction:column;align-items:flex-start;gap:.4rem}
  .sf-copy,.sf-email{font-size:.72rem;color:rgba(255,255,255,.28)}
  @media(max-width:768px){.sf-inner{grid-template-columns:1fr;gap:2.5rem}.sf-links{grid-template-columns:repeat(2,1fr)}.sf-bottom{flex-direction:column;align-items:flex-start}}

@keyframes fadeUp{from{opacity:0;transform:translateY(22px)}to{opacity:1;transform:translateY(0)}}
  .fu1{animation:fadeUp .65s ease both}
  .fu2{animation:fadeUp .65s .1s ease both}
  .fu3{animation:fadeUp .65s .2s ease both}
  .fu4{animation:fadeUp .65s .3s ease both}

  /* HAMBURGER NAV */
  .hamburger{display:none;flex-direction:column;gap:4px;background:none;border:none;cursor:pointer;padding:6px;border-radius:6px}
  .hamburger span{display:block;width:20px;height:2px;background:var(--ink);border-radius:2px;transition:all .25s}
  .mobile-menu{display:none;position:fixed;top:58px;left:0;right:0;background:rgba(255,253,249,.98);backdrop-filter:blur(16px);border-bottom:1px solid var(--stone);padding:1.25rem 2rem 1.5rem;z-index:99;flex-direction:column;gap:.2rem}
  .mobile-menu.open{display:flex}
  .mobile-menu a{font-size:.9rem;font-weight:500;color:var(--muted);text-decoration:none;padding:.6rem 0;border-bottom:1px solid var(--stone);transition:color .15s}
  .mobile-menu a:last-child{border-bottom:none}
  .mobile-menu a:hover{color:var(--ink)}
  .mobile-menu .mm-cta{color:var(--orange);font-weight:700}
  @media(max-width:900px){
    nav{padding:0 1.25rem}
    .hero{grid-template-columns:1fr;padding-left:1.25rem;padding-right:1.25rem}
    .hero-right{display:none}
    .why-grid,.for-grid,.phil-grid,.proof-grid{grid-template-columns:1fr}
    .what-layout{grid-template-columns:1fr;gap:2rem}
    .pb-inner{grid-template-columns:1fr}
    .nav-center{display:none}
    .nav-right .btn-nav,.nav-signin{display:none}
    .hamburger{display:flex}
    .hero-left{padding-top:2rem;padding-bottom:2.5rem}
    .hero-left h1{font-size:clamp(2.2rem,8vw,3.5rem)}
    .page-header{padding:calc(58px + 2rem) 1.25rem 2rem}
    section{padding-left:1.25rem!important;padding-right:1.25rem!important}
    .philosophy-bar{padding-left:1.25rem!important;padding-right:1.25rem!important}
    .proof-section{padding-left:1.25rem!important;padding-right:1.25rem!important}
    .cta-wrap{padding-left:1.25rem!important;padding-right:1.25rem!important}
  }
  @media(max-width:640px){
    .story-cards-desktop{display:none!important}
    .story-cards-mobile-scroll{display:flex!important}
    .what-grid{grid-template-columns:1fr!important}
    .proof-grid{grid-template-columns:1fr!important}
    .proof-stat-row{display:grid!important;grid-template-columns:1fr 1fr;gap:1.5rem 2rem;justify-items:center;text-align:center}
    .proof-section{padding:3rem 1.25rem}
    .proof-text{font-size:.9rem!important}
    .hero-left h1{font-size:2.2rem}
    .hero-left p{font-size:.95rem}
    .hero-ctas{flex-direction:column;align-items:flex-start}
    .si{padding-left:1.25rem;padding-right:1.25rem}
    /* Mobile hero: don't hold full viewport height when right column is hidden */
    .hero{min-height:0!important;padding-top:58px;padding-bottom:0}
    .hero-left{padding-top:1.75rem!important;padding-bottom:2rem!important}
    /* First section after hero: reduce top padding so it doesn't feel detached */
    .hero+section,.hero~section:first-of-type{padding-top:2.5rem!important}
    section{padding-top:3rem!important;padding-bottom:3rem!important}
  }
  .mm-section{display:flex;flex-direction:column;border-bottom:1px solid var(--stone);padding-bottom:.25rem;margin-bottom:.25rem}
  .mm-label{font-size:.58rem;letter-spacing:.2em;text-transform:uppercase;color:var(--muted);font-weight:700;padding:.55rem 0 .2rem .75rem}
  .mm-sub{padding-left:.75rem !important;font-size:.85rem !important;border-bottom:none !important}
  .mm-sub:last-child{border-bottom:none}

  @media(max-width:640px){.use-toggle{flex-wrap:wrap}.use-btn{flex:1;justify-content:center}
    .hero-left h1{font-size:clamp(2.2rem,8vw,3.5rem)!important}
    .hero-left p{font-size:.92rem!important}
    [style*="grid-template-columns:repeat(3,1fr)"]{grid-template-columns:1fr!important}
    [style*="grid-template-columns: repeat(3, 1fr)"]{grid-template-columns:1fr!important}
    [style*="grid-template-columns:1fr 1fr"]{grid-template-columns:1fr!important}
    [style*="grid-template-columns: 1fr 1fr"]{grid-template-columns:1fr!important}
    [style*="grid-template-columns:1fr 2fr"]{grid-template-columns:1fr!important}
    [style*="grid-template-columns: 1fr 2fr"]{grid-template-columns:1fr!important}
    [style*="grid-template-columns:1fr 1.1fr"]{grid-template-columns:1fr!important}
    .page-header{padding:calc(58px + 2rem) 1.25rem 2rem!important}
    .si{padding-left:1.25rem!important;padding-right:1.25rem!important}
    }
</style>
</head>
