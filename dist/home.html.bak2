              <!-- Axis labels -->
              <text x="99" y="8" font-size="6" font-weight="700" fill="rgba(255,255,255,.7)" font-family="Arial" text-anchor="middle">ENGAGE</text>
              <text x="99" y="108" font-size="6" font-weight="700" fill="rgba(255,255,255,.5)" font-family="Arial" text-anchor="middle">WITHDRAW</text>
            </svg>
            <div style="display:flex;gap:.85rem;">
              <div style="display:flex;align-items:center;gap:.35rem;"><div style="width:7px;height:7px;border-radius:50%;background:#E8673A;"></div><span style="font-size:.56rem;color:rgba(255,255,255,.65);font-family:'DM Sans',sans-serif;font-weight:600;">Sarah · W — The Reacher</span></div>
              <div style="display:flex;align-items:center;gap:.35rem;"><div style="width:7px;height:7px;border-radius:50%;background:#7C3AED;"></div><span style="font-size:.56rem;color:rgba(255,255,255,.65);font-family:'DM Sans',sans-serif;font-weight:600;">James · Y — The Feeler</span></div>
            </div>
          </div>
