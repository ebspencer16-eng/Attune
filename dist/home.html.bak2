                <div style="flex:1;background:rgba(255,255,255,.08);border-radius:3px;height:5px;overflow:hidden;"><div style="background:#5B7FE8;height:5px;width:80%;border-radius:3px;"></div></div>
                <span style="font-size:.6rem;color:rgba(255,255,255,.55);font-family:'DM Sans',sans-serif;white-space:nowrap;">Withdraw first</span>
