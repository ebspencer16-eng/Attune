              </defs>
              <!-- Quadrant fills -->
              <rect x="1" y="1" width="97" height="53" rx="5" fill="url(#mg1)" fill-opacity=".8"/>
              <rect x="101" y="1" width="97" height="53" rx="5" fill="url(#mg2)" fill-opacity=".8"/>
              <rect x="1" y="57" width="97" height="51" rx="5" fill="url(#mg3)" fill-opacity=".8"/>
              <rect x="101" y="57" width="97" height="51" rx="5" fill="url(#mg4)" fill-opacity=".8"/>
              <!-- Quadrant labels -->
              <text x="10" y="16" font-size="8" font-weight="700" fill="#E8673A" font-family="Arial" opacity=".9">W</text>
              <text x="188" y="16" font-size="8" font-weight="700" fill="#1B5FE8" font-family="Arial" text-anchor="end" opacity=".9">X</text>
              <text x="10" y="100" font-size="8" font-weight="700" fill="#7C3AED" font-family="Arial" opacity=".9">Y</text>
