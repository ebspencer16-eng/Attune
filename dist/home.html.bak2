                  <span style="font-size:.58rem;background:rgba(232,103,58,.2);color:#E8673A;padding:.1rem .4rem;border-radius:4px;font-weight:600;font-family:'DM Sans',sans-serif;">Sarah: James</span>
                  <span style="font-size:.58rem;background:rgba(27,95,232,.2);color:#7B9FFF;padding:.1rem .4rem;border-radius:4px;font-weight:600;font-family:'DM Sans',sans-serif;">James: Both</span>
                </div>
