    <span style="font-size:.7rem;color:rgba(255,255,255,.70);font-style:italic;">How's Attune working for you?</span>
    <div id="spark-feedback-strip" style="display:flex;gap:.4rem;">
      <button onclick="window._sparkFeedback('love')" style="background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.12);border-radius:6px;padding:.3rem .65rem;font-size:.72rem;color:rgba(255,255,255,.6);cursor:pointer;">❤️ Love it</button>
      <button onclick="window._sparkFeedback('good')" style="background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.12);border-radius:6px;padding:.3rem .65rem;font-size:.72rem;color:rgba(255,255,255,.6);cursor:pointer;">👍 Pretty good</button>
      <button onclick="window._sparkFeedback('suggest')" style="background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.12);border-radius:6px;padding:.3rem .65rem;font-size:.72rem;color:rgba(255,255,255,.6);cursor:pointer;">💬 Suggest something</button>
    </div>
    <span id="spark-feedback-thanks" style="font-size:.7rem;color:#4ade80;display:none;">Thanks for the feedback ✓</span>
  </div>
  <script>
  window._sparkFeedback = function(t) {
    if(t==='suggest'){
      var strip=document.getElementById('spark-feedback-strip');
      if(!strip)return;
      strip.innerHTML='<input id="sfb-inp" type="text" placeholder="What would make Attune better?" style="background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.25);border-radius:6px;padding:.3rem .65rem;font-size:.72rem;color:white;width:220px;font-family:sans-serif;"><button onclick="(function(){var m=document.getElementById('sfb-inp').value.trim();if(m)fetch('/api/send-feedback',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({source:'footer_quick',rating:'suggest',message:m,page:window.location.pathname})}).catch(function(){});document.getElementById('spark-feedback-strip').innerHTML='';document.getElementById('spark-feedback-thanks').style.display='inline';})()" style="background:rgba(232,103,58,.9);border:none;border-radius:6px;padding:.3rem .65rem;font-size:.72rem;color:white;cursor:pointer;margin-left:.35rem;">Send</button>';
      setTimeout(function(){var i=document.getElementById('sfb-inp');if(i)i.focus();},50);
      return;
    }
    fetch('/api/send-feedback',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({source:'footer_quick',rating:t==='love'?3:2,page:window.location.pathname})}).catch(function(){});
    document.getElementById('spark-feedback-strip').innerHTML='';
    document.getElementById('spark-feedback-thanks').style.display='inline';
  };

  </script>
</footer>

<script>
function toggleMenu() {
  const m = document.getElementById('mobile-menu');
  m.classList.toggle('open');
}
document.addEventListener('click', function(e) {
  const menu = document.getElementById('mobile-menu');
  const btn = document.getElementById('hamburger');
  if (menu.classList.contains('open') && !menu.contains(e.target) && !btn.contains(e.target)) {
    menu.classList.remove('open');
  }
});

const descs = {
  foryou: "Each of you answers on your own. Identify who you are individually and as a couple — and learn how to work and grow together.",
  gift: "Purchase Attune for a couple you love. They'll each complete the exercises on their own, and unlock a joint understanding of themselves and each other that most couples never find."
};
const ctas = {
  foryou: "Start your exercises →",
  gift: "Browse gifts & packages →"
};
const ctaLinks = {
  foryou: "/offerings",
  gift: "/offerings"
};
function setUse(mode) {
  document.getElementById('btn-foryou').className = 'use-btn' + (mode==='foryou'?' active':'');
  document.getElementById('btn-gift').className = 'use-btn' + (mode==='gift'?' active':'');
  document.getElementById('use-desc').textContent = descs[mode];
  document.getElementById('hero-cta').textContent = ctas[mode];
  document.getElementById('hero-cta').href = ctaLinks[mode];
}

  // Close mobile menu on outside tap
  document.addEventListener('click', function(e) {
    const menu = document.getElementById('mobile-menu');
    const burger = document.getElementById('hamburger');
    if (menu && menu.classList.contains('open') && !menu.contains(e.target) && !burger.contains(e.target)) {
      menu.classList.remove('open');
      burger.classList.remove('open');
    }
  });
</script>
</body>
</html>
