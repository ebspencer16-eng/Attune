          <!-- Mini 2x2 couple map — SVG for reliable mobile rendering -->
          <div style="margin-top:1.1rem;">
            <svg viewBox="0 0 200 110" style="width:100%;display:block;margin-bottom:.6rem;" xmlns="http://www.w3.org/2000/svg">
              <defs>
                <linearGradient id="mg1" x1="0%" y1="0%" x2="100%" y2="100%"><stop offset="0%" stop-color="#FFD0B8"/><stop offset="100%" stop-color="#FFBFA0"/></linearGradient>
                <linearGradient id="mg2" x1="0%" y1="0%" x2="100%" y2="100%"><stop offset="0%" stop-color="#C8D5FF"/><stop offset="100%" stop-color="#B8C8FF"/></linearGradient>
                <linearGradient id="mg3" x1="0%" y1="0%" x2="100%" y2="100%"><stop offset="0%" stop-color="#DDD0FF"/><stop offset="100%" stop-color="#CFC0FF"/></linearGradient>
