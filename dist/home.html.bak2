      <!-- Card 1 clone: Couple Type -->
      <div style="background:linear-gradient(160deg,#2d1240,#461860,#2d1240);border-radius:20px;overflow:hidden;display:flex;flex-direction:column;position:relative;min-height:320px;min-width:calc(85vw - 1rem);max-width:320px;flex-shrink:0;scroll-snap-align:start;">
