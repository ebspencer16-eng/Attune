            <div style="font-family:'Playfair Display',Georgia,serif;font-size:4.5rem;font-weight:700;color:white;line-height:.9;letter-spacing:-.03em;margin-bottom:.4rem;">28%</div>
            <div style="font-size:.88rem;color:rgba(255,255,255,.82);font-family:'DM Sans',sans-serif;font-weight:300;margin-bottom:1.25rem;">aligned on expectations</div>
